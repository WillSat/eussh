{
  "productName": "eussh",
  "version": "1.3.3",
  "identifier": "com.eussh.desktop",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "eussh",
        "width": 1100,
        "height": 720,
        "minWidth": 780,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "backgroundColor": "#1e1e1e",
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com http://ip-api.com; img-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
